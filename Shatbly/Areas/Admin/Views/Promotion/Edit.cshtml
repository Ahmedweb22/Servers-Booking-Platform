@model PromotionUpdateResponseVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">Edit Promotion</h3>
        </div>
        <!-- Back -->
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/Promotion/Index" class="btn btn-danger">
                >> Back
            </a>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="@Model.Promotion.Id" />
                <div class="mb-3">
                    <label asp-for="Promotion.Title" class="form-label">Title</label>
                    <input asp-for="Promotion.Title" class="form-control" id="Title" placeholder="Enter title" value="@Model.Promotion.Title">
                    <span asp-validation-for="Promotion.Title" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.Description" class="form-label">Description</label>
                    <input asp-for="Promotion.Description" class="form-control" id="Description" placeholder="Enter description" value="@Model.Promotion.Description">
                    <span asp-validation-for="Promotion.Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.DiscountValue" class="form-label">Discount Value</label>
                    <input asp-for="Promotion.DiscountValue" type="number" step="0.01" class="form-control" placeholder="Enter discount value" value="@Model.Promotion.DiscountValue">
                    <span asp-validation-for="Promotion.DiscountValue" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.DiscountType" class="form-label">Discount Type</label>
                    <select asp-for="Promotion.DiscountType"
                            asp-items="Html.GetEnumSelectList<DiscountType>()"
                            class="form-select">
                    </select>
                    <span asp-validation-for="Promotion.DiscountType" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.MinOrderValue" class="form-label">Minimum Order Value</label>
                    <input asp-for="Promotion.MinOrderValue" type="number" step="0.01" class="form-control" placeholder="Enter minimum order value" value="@(Model.Promotion.MinOrderValue == default ? "" : Model.Promotion.MinOrderValue.ToString("0.##"))">
                    <span asp-validation-for="Promotion.MinOrderValue" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.StartDate" class="form-label"></label>
                    <input asp-for="Promotion.StartDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Promotion.StartDate" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.EndDate" class="form-label"></label>
                    <input asp-for="Promotion.EndDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Promotion.EndDate" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Service Category</label>
                    <select asp-for="Promotion.CategoryId" class="form-select">
                        <option value="">-- Select Service Category --</option>
                        @foreach (var category in Model.ServiceCategories)
                        {
                            <option value="@category.Id" selected="@(category.Id == Model.Promotion.CategoryId)">
                                @category.NameEn
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Promotion.CategoryId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Promotion.IsActive" class="form-label">Status</label>
                    <select asp-for="Promotion.IsActive" class="form-select" id="IsActive">
                        @if (Model.Promotion.IsActive)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">Inactive</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>Inactive</option>
                        }
                      
                    </select>
                    <span asp-validation-for="Promotion.IsActive" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success">Update</button>
            </form>
        </div>
    </div>
</div>
<script>
    function previewImage(event) {
    const input = event.target;
    const preview = document.getElementById('preview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
    }
</script>
@section Scripts {
    <partial name="~/Views/Shared/_NotificationPartial.cshtml" />
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}

