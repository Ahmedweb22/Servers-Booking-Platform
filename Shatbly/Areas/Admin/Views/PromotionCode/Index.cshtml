@model PromotionCodesVM

<div class="container">

    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">All Promotion Codes</h3>
        </div>
        <!-- Create -->
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/PromotionCode/Create" class="btn btn-success">
                + Create New
            </a>
        </div>
    </div>
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important">
                <div class="col-md-6">
                    <form>
                        <div class="row">
                            <div class="col-md-3">
                                <input type="text" name="code" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="title..." />
                            </div>
                            <div class="col-md-2 ">
                                <button type="submit" class="btn btn-primary">Search</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
        </section>

     

        <div class="card shadow-sm">
            <div class="card-body p-0">

                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Code</th>
                            <th scope="col">MaxUses</th>
                            <th scope="col">UsedCount</th>
                            <th scope="col">Status</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.PromotionCodes)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Code</td>
                                <td>@item.MaxUses</td>
                                <td>@item.UsedCount</td>
                                @if (item.IsActive)
                                {
                                    <td>
                                        <span class="badge bg-success">Active</span>
                                    </td>
                                }
                                else
                                {
                                    <td>
                                        <span class="badge bg-secondary">Inactive</span>
                                    </td>
                                }
                                @* <!-- Read -->
                                    <a asp-action="Details" asp-route-id=""
                                           class="btn btn-sm btn-outline-primary">
                                        Details
                                    </a> *@
                                @* @if (User.IsInRole(SD.ROLE_SUPER_ADMIN))
                                { *@
                                    <td>
                                        <!-- Update -->
                                        <a href="/Admin/PromotionCode/Edit/@item.Id"
                                               class="btn btn-sm btn-outline-success">
                                            Edit
                                        </a>

                                        <!-- Delete -->
                                        <a href="/Admin/PromotionCode/Delete/@item.Id"
                                               class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    </td>
                                @* }
                                else
                                {
                                    <td>
                                        No Actions Available!!
                                    </td>
                                } *@
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>

        <div class="row">
            <div class="col-12 d-flex justify-content-center">
                <nav aria-label="Page navigation example">
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Admin/PromotionCode/Index?page=@(Model.CurrentPage - 1)">Previous</a>
                            </li>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <li class="page-item active">
                                    <a class="page-link" href="/Admin/PromotionCode/Index?page=@i">@i</a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="/Admin/PromotionCode/Index?page=@i">@i</a>
                                </li>
                            }
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="/Admin/PromotionCode/Index?page=@(Model.CurrentPage + 1)">Next</a>
                            </li>
                        }
                 
                    </ul>
                </nav>
            </div>
        </div>

    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const deleteLinks = document.querySelectorAll('a.btn-outline-danger');
            deleteLinks.forEach(function(link) {
                link.addEventListener('click', function(event) {
                    event.preventDefault();
                    const url = this.href;
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Yes, delete it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = url;
                        }
                    });
                });
            });
        });
    </script>
