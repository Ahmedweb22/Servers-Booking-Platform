@model ServiceCategory
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">Edit Service Category</h3>
        </div>
        <!-- Back -->
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/ServiceCategory/Index" class="btn btn-danger">
                >> Back
            </a>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Icon" />
                <div class="mb-3">
                    <label asp-for="NameAr" class="form-label">Name (Ar)</label>
                    <input asp-for="NameAr" class="form-control" id="NameAr" placeholder="Enter name in Arabic" name="nameAr" value="@Model.NameAr">
                    <span asp-validation-for="NameAr" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="NameEn" class="form-label">Name (En)</label>
                    <input asp-for="NameEn" class="form-control" id="NameEn" placeholder="Enter name in English" name="nameEn" value="@Model.NameEn">
                    <span asp-validation-for="NameEn" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Icon" class="form-label">Service Category Icon</label>
                    <input asp-for="Icon" type="file" class="form-control" id="Icon" placeholder="Enter service category icon" name="icon" onchange="previewImage(event)">
                    <span asp-validation-for="Icon" class="text-danger"></span>
                </div>
                <!-- Image Preview Area -->
                <div class="mb-3" id="imagePreviewContainer">
                    <label class="form-label">Icon Preview</label>
                    <div class="border rounded p-2 text-center" style="max-width: 300px;">
                        @if (!string.IsNullOrEmpty(Model.Icon))
                        {
                            <img id="imagePreview" src="~/img/service_categories/@Model.Icon" alt="Icon Preview" style="max-width: 100%; max-height: 250px;" />
                        }
                        else
                        {
                            <img id="imagePreview" src="#" alt="Icon Preview" style="max-width: 100%; max-height: 250px; display: none;" />
                            <p id="noImageText" class="text-muted">No icon uploaded yet</p>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="IsActive" class="form-label">Status</label>
                    <select asp-for="IsActive" class="form-select" id="IsActive">
                        @if (Model.IsActive)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">Inactive</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>Inactive</option>
                        }
                      
                    </select>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success">Update</button>
            </form>
        </div>
    </div>
</div>
<script>
    function previewImage(event) {
    const input = event.target;
    const preview = document.getElementById('preview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
    }
</script>
@section Scripts {
    <partial name="~/Views/Shared/_NotificationPartial.cshtml" />
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}

