@model Shatbly.ViewModels.BookingWizardViewModel
@using Shatbly.Models
@using Stripe

@{
    ViewData["Title"] = "Booking Wizard";
}

<style>
    :root {
        --page-bg: #f5efe6;
        --panel: #fffdf9;
        --ink: #1f2937;
        --muted: #6b7280;
        --accent: #c26a2d;
        --accent-soft: #f8d7bd;
        --line: #e7d7c8;
        --success: #1f7a5a;
    }

    body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, sans-serif;
        color: var(--ink);
        background: radial-gradient(circle at top right, rgba(194, 106, 45, 0.14), transparent 26%), linear-gradient(180deg, #fcfaf7 0%, var(--page-bg) 100%);
    }

    .booking-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 32px 20px 48px;
    }

    .hero {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    .hero-card, .panel, .summary-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: 0 18px 55px rgba(51, 37, 24, 0.08);
    }

    .hero-card {
        padding: 28px;
    }

    .eyebrow {
        display: inline-flex;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .hero h1 {
        margin: 14px 0 10px;
        font-size: clamp(2rem, 3.6vw, 3.2rem);
        line-height: 1.02;
    }

    .hero p {
        margin: 0;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    .hero-metrics {
        padding: 28px;
        display: grid;
        gap: 14px;
        align-content: start;
    }

    .metric {
        padding: 16px;
        border-radius: 18px;
        background: #faf6f0;
        border: 1px solid var(--line);
    }

        .metric strong {
            display: block;
            margin-bottom: 6px;
            font-size: 1.3rem;
        }

    .wizard-grid {
        display: grid;
        grid-template-columns: 1.7fr 0.9fr;
        gap: 22px;
        align-items: start;
    }

    .panel {
        padding: 26px;
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 22px;
    }

    .step-chip {
        padding: 12px 10px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: #fbf6ef;
        font-size: 0.88rem;
        color: var(--muted);
        text-align: center;
    }

        .step-chip.active {
            background: linear-gradient(135deg, #1e3a34, #2f5f55);
            color: #fff;
            border-color: transparent;
        }

    .wizard-step {
        display: none;
        animation: fade-up 180ms ease;
    }

        .wizard-step.active {
            display: block;
        }

    @@keyframes fade-up {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .section-title {
        margin: 0 0 6px;
        font-size: 1.35rem;
    }

    .section-copy {
        margin: 0 0 20px;
        color: var(--muted);
        line-height: 1.55;
    }

    .choice-grid, .radio-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
    }

    .choice-card {
        position: relative;
        padding: 16px;
        border-radius: 20px;
        border: 1px solid var(--line);
        background: #fff;
    }

        .choice-card input {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }

        .choice-card:has(input:checked) {
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(194, 106, 45, 0.14);
            background: #fff8f2;
        }

        .choice-card strong {
            display: block;
            margin-bottom: 8px;
        }

        .choice-card span {
            color: var(--muted);
            font-size: 0.93rem;
            line-height: 1.45;
        }

    .field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .field, .full {
        display: grid;
        gap: 8px;
    }

    .full {
        grid-column: 1 / -1;
    }

    label {
        font-weight: 600;
        font-size: 0.95rem;
    }

    input, select, textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 13px 14px;
        border-radius: 16px;
        border: 1px solid #d9c5b2;
        font: inherit;
        background: #fff;
    }

    textarea {
        min-height: 110px;
        resize: vertical;
    }

    .hint, .validation, .small-note {
        color: var(--muted);
        font-size: 0.88rem;
    }

    .validation {
        color: #b42318;
    }

    .button-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 24px;
    }

    .btn {
        appearance: none;
        border: 0;
        border-radius: 16px;
        padding: 13px 18px;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-primary {
        background: linear-gradient(135deg, #c26a2d, #de8a51);
        color: #fff;
    }

    .btn-secondary {
        background: #f4ede6;
        color: var(--ink);
        border: 1px solid var(--line);
    }

    .summary-card {
        padding: 24px;
        position: sticky;
        top: 20px;
    }

        .summary-card h3 {
            margin-top: 0;
        }

    .summary-line {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px dashed var(--line);
        font-size: 0.96rem;
    }

        .summary-line:last-child {
            border-bottom: 0;
        }

    .summary-total {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .success-note {
        margin-top: 18px;
        padding: 14px 16px;
        border-radius: 16px;
        background: #eef9f3;
        color: var(--success);
        font-size: 0.92rem;
        line-height: 1.5;
    }

    .banner {
        margin-bottom: 16px;
        padding: 14px 16px;
        border-radius: 18px;
        font-size: 0.95rem;
    }

        .banner.error {
            background: #fef3f2;
            color: #b42318;
            border: 1px solid #fecdca;
        }

    @@media (max-width: 900px) {
        .hero, .wizard-grid, .field-grid {
            grid-template-columns: 1fr;
        }

        .steps {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .summary-card {
            position: static;
        }
    }
</style>

<div class="booking-shell">
    <div class="hero">
        <section class="hero-card">
            <div class="eyebrow">Booking System</div>
            <h1>Five steps from service selection to payment confirmation.</h1>
            <p>
                This wizard supports scheduled and instant bookings, limits date selection to open slots only,
                keeps worker confirmation within 30 minutes, and includes recurring plans plus refund-aware changes.
            </p>
        </section>

        <aside class="hero-metrics hero-card">
            <div class="metric">
                <strong>Available slots only</strong>
                <span class="hint">Step 2 updates live from each worker’s existing bookings.</span>
            </div>
            <div class="metric">
                <strong>Instant or scheduled</strong>
                <span class="hint">Instant chooses the earliest open slot for the selected worker.</span>
            </div>
            <div class="metric">
                <strong>Recurring ready</strong>
                <span class="hint">Weekly and monthly bookings automatically adjust the final price.</span>
            </div>
        </aside>
    </div>

    <div class="wizard-grid">
        <form asp-controller="BookingSystem" asp-action="Create" method="post" class="panel" id="bookingForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="banner error"></div>

            <div class="steps">
                <div class="step-chip active" data-step-chip="1">1. Service + worker</div>
                <div class="step-chip" data-step-chip="2">2. Date + time</div>
                <div class="step-chip" data-step-chip="3">3. Address</div>
                <div class="step-chip" data-step-chip="4">4. Review</div>
                <div class="step-chip" data-step-chip="5">5. Payment</div>
            </div>

            <section class="wizard-step active" data-step="1">
                <h2 class="section-title">Select service and worker</h2>
                <p class="section-copy">Start with the service, assign the worker, and decide whether this should be booked instantly or scheduled for later.</p>

                <div class="field-grid">
                    <div class="field">
                        <label asp-for="ServiceId"></label>
                        <select asp-for="ServiceId" asp-items="Model.ServiceOptions" id="serviceSelect"></select>
                        <span asp-validation-for="ServiceId" class="validation"></span>
                    </div>

                    <div class="field">
                        <label asp-for="WorkerId"></label>
                        <select asp-for="WorkerId" asp-items="Model.WorkerOptions" id="workerSelect"></select>
                        <span asp-validation-for="WorkerId" class="validation"></span>
                    </div>
                </div>

                <div class="radio-grid" style="margin-top:18px;">
                    <label class="choice-card">
                        <input asp-for="BookingType" type="radio" value="@BookingTypes.Scheduled" />
                        <strong>Scheduled booking</strong>
                        <span>Customer picks the exact day and time from the available schedule.</span>
                    </label>
                    <label class="choice-card">
                        <input asp-for="BookingType" type="radio" value="@BookingTypes.Instant" />
                        <strong>Instant booking</strong>
                        <span>We lock the earliest open slot and add an express convenience fee.</span>
                    </label>
                </div>

                <div class="button-row">
                    <span></span>
                    <button type="button" class="btn btn-primary" data-next-step>Continue</button>
                </div>
            </section>

            <section class="wizard-step" data-step="2">
                <h2 class="section-title">Choose date and time</h2>
                <p class="section-copy">Only valid worker slots are shown here. If you keep instant booking enabled, the earliest available slot will be selected for you.</p>

                <div class="field-grid">
                    <div class="field">
                        <label asp-for="SelectedDate">Available dates</label>
                        <select asp-for="SelectedDate" id="dateSelect"></select>
                        <span asp-validation-for="SelectedDate" class="validation"></span>
                    </div>

                    <div class="field">
                        <label asp-for="SelectedTime">Available times</label>
                        <select asp-for="SelectedTime" id="timeSelect"></select>
                        <span asp-validation-for="SelectedTime" class="validation"></span>
                    </div>
                </div>

                <div class="success-note">
                    Worker confirmation window: once the booking is placed, the assigned worker has 30 minutes to accept or reject the request.
                </div>

                <div class="button-row">
                    <button type="button" class="btn btn-secondary" data-prev-step>Back</button>
                    <button type="button" class="btn btn-primary" data-next-step>Continue</button>
                </div>
            </section>

            <section class="wizard-step" data-step="3">
                <h2 class="section-title">Select or add address</h2>
                <p class="section-copy">Choose a saved-style address preset or replace it with a new one. This step also captures the customer contact details tied to the booking.</p>

                <div class="field-grid">
                    <div class="field">
                        <label>Quick address presets</label>
                        <select id="addressPreset">
                            <option value="">Keep current address</option>
                            @foreach (var preset in Model.AddressPresets)
                            {
                                <option value="@preset.Value">@preset.Text</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label asp-for="AddressLabel"></label>
                        <input asp-for="AddressLabel" />
                        <span asp-validation-for="AddressLabel" class="validation"></span>
                    </div>

                    <div class="full">
                        <label asp-for="AddressLine"></label>
                        <input asp-for="AddressLine" id="addressLineInput" />
                        <span asp-validation-for="AddressLine" class="validation"></span>
                    </div>

                    <div class="field">
                        <label asp-for="CustomerName"></label>
                        <input asp-for="CustomerName" />
                        <span asp-validation-for="CustomerName" class="validation"></span>
                    </div>

                    <div class="field">
                        <label asp-for="CustomerPhone"></label>
                        <input asp-for="CustomerPhone" />
                        <span asp-validation-for="CustomerPhone" class="validation"></span>
                    </div>

                    <div class="full">
                        <label asp-for="CustomerEmail"></label>
                        <input asp-for="CustomerEmail" />
                        <span asp-validation-for="CustomerEmail" class="validation"></span>
                    </div>
                </div>

                <div class="button-row">
                    <button type="button" class="btn btn-secondary" data-prev-step>Back</button>
                    <button type="button" class="btn btn-primary" data-next-step>Continue</button>
                </div>
            </section>

            <section class="wizard-step" data-step="4">
                <h2 class="section-title">Review booking details</h2>
                <p class="section-copy">Check notes, recurring preferences, and the live price calculation before moving to payment.</p>

                <div class="field-grid">
                    <div class="field">
                        <label asp-for="RecurrencePattern">Recurring booking</label>
                        <select asp-for="RecurrencePattern" asp-items="Model.RecurrenceOptions"></select>
                    </div>

                    <div class="field">
                        <label>Estimated duration</label>
                        <input value="1 hour" readonly />
                    </div>

                    <div class="full">
                        <label asp-for="Notes"></label>
                        <textarea asp-for="Notes" placeholder="Gate code, parking notes, cleaning instructions, preferred contact method..."></textarea>
                        <span asp-validation-for="Notes" class="validation"></span>
                    </div>
                </div>

                <div class="success-note">
                    Refund policy: 100% refund for cancellations 24+ hours before the slot, 50% for 2-24 hours, and no refund within the final 2 hours.
                </div>

                <div class="button-row">
                    <button type="button" class="btn btn-secondary" data-prev-step>Back</button>
                    <button type="button" class="btn btn-primary" data-next-step>Continue</button>
                </div>
            </section>

            <section class="wizard-step" data-step="5">
                <h2 class="section-title">Payment and confirmation</h2>
                <p class="section-copy">Choose the payment method and submit the booking. Card and wallet payments are marked paid immediately, while cash remains pending.</p>

                <div class="radio-grid">
                    @foreach (var paymentOption in Model.PaymentOptions)
                    {
                        <label class="choice-card">
                            <input asp-for="PaymentMethod" type="radio" value="@paymentOption.Value" />
                            <strong>@paymentOption.Text</strong>
                            <span>@(paymentOption.Value == "Cash" ? "Collected on arrival." : "Marked as paid once the booking is confirmed.")</span>
                        </label>
                    }
                </div>

                <div class="success-note">
                    After confirmation, the booking details page will let the customer reschedule or cancel with the refund policy applied automatically.
                </div>

                <div class="button-row">
                    <button type="button" class="btn btn-secondary" data-prev-step>Back</button>
                    <button type="submit" class="btn btn-primary">Confirm booking</button>
                </div>
            </section>
        </form>

        <aside class="summary-card">
            <h3>Live summary</h3>
            <div class="summary-line">
                <span>Service</span>
                <strong id="summaryService">@Model.SelectedServiceName</strong>
            </div>
            <div class="summary-line">
                <span>Worker</span>
                <strong id="summaryWorker">@Model.SelectedWorkerName</strong>
            </div>
            <div class="summary-line">
                <span>Slot</span>
                <strong id="summarySlot">@(string.IsNullOrWhiteSpace(Model.SelectedDate) ? "Select step 2" : $"{Model.SelectedDate} {Model.SelectedTime}")</strong>
            </div>
            <div class="summary-line">
                <span>Address</span>
                <strong id="summaryAddress">@(string.IsNullOrWhiteSpace(Model.AddressLine) ? "Add in step 3" : Model.AddressLine)</strong>
            </div>
            <div class="summary-line">
                <span>Service price</span>
                <strong>EGP <span id="servicePrice">@Model.ServicePrice.ToString("0.00")</span></strong>
            </div>
            <div class="summary-line">
                <span>Convenience fee</span>
                <strong>EGP <span id="convenienceFee">@Model.ConvenienceFee.ToString("0.00")</span></strong>
            </div>
            <div class="summary-line">
                <span>Recurring discount</span>
                <strong>- EGP <span id="discountAmount">@Model.DiscountAmount.ToString("0.00")</span></strong>
            </div>
            <div class="summary-total">
                <span>Total</span>
                <span>EGP <span id="totalPrice">@Model.TotalPrice.ToString("0.00")</span></span>
            </div>

            <div class="success-note">
                Scheduled bookings create a pending record immediately. Worker acceptance or rejection can then be handled within the 30-minute confirmation window.
            </div>
        </aside>
    </div>
</div>

<script>
    (() => {
        const modelAvailability = @Html.Raw(Model.AvailabilityJson);
        const steps = Array.from(document.querySelectorAll("[data-step]"));
        const stepChips = Array.from(document.querySelectorAll("[data-step-chip]"));
        const nextButtons = Array.from(document.querySelectorAll("[data-next-step]"));
        const prevButtons = Array.from(document.querySelectorAll("[data-prev-step]"));
        const workerSelect = document.getElementById("workerSelect");
        const serviceSelect = document.getElementById("serviceSelect");
        const dateSelect = document.getElementById("dateSelect");
        const timeSelect = document.getElementById("timeSelect");
        const addressPreset = document.getElementById("addressPreset");
        const addressLineInput = document.getElementById("addressLineInput");
        const recurrenceSelect = document.getElementById("RecurrencePattern");
        const bookingTypeInputs = Array.from(document.querySelectorAll("input[name='BookingType']"));
        const serviceOptions = Array.from(serviceSelect.options).map(option => {
            const [name, pricePart] = option.text.split(" - EGP ");
            return { id: option.value, name, price: Number(pricePart || "0") };
        });

        let currentStep = 1;

        function getBookingType() {
            const selected = bookingTypeInputs.find(input => input.checked);
            return selected ? selected.value : "Scheduled";
        }

        function updateSteps(step) {
            currentStep = step;
            steps.forEach(section => section.classList.toggle("active", Number(section.dataset.step) === step));
            stepChips.forEach(chip => chip.classList.toggle("active", Number(chip.dataset.stepChip) === step));
        }

        function fillSelect(select, items, placeholder) {
            select.innerHTML = "";

            if (!items.length) {
                const option = document.createElement("option");
                option.value = "";
                option.textContent = placeholder;
                select.appendChild(option);
                return;
            }

            items.forEach(item => {
                const option = document.createElement("option");
                option.value = item.value;
                option.textContent = item.label;
                select.appendChild(option);
            });
        }

        function syncAvailability() {
            const workerId = workerSelect.value;
            const datesForWorker = modelAvailability[workerId] || {};
            const dateItems = Object.keys(datesForWorker).map(date => ({ value: date, label: date }));
            fillSelect(dateSelect, dateItems, "No available dates");

            if (getBookingType() === "Instant" && dateItems.length) {
                dateSelect.value = dateItems[0].value;
            } else if ("@Model.SelectedDate") {
                dateSelect.value = "@Model.SelectedDate";
            }

            syncTimes();
        }

        function syncTimes() {
            const workerId = workerSelect.value;
            const selectedDate = dateSelect.value;
            const times = ((modelAvailability[workerId] || {})[selectedDate] || []).map(time => ({
                value: time,
                label: time
            }));

            fillSelect(timeSelect, times, "No slots");

            if (times.length) {
                timeSelect.value = getBookingType() === "Instant" ? times[0].value : ("@Model.SelectedTime" || times[0].value);
            }

            updateSummary();
        }

        function updatePricing() {
            const selectedService = serviceOptions.find(option => option.id === serviceSelect.value) || { name: "Choose a service", price: 0 };
            const bookingType = getBookingType();
            const recurrence = recurrenceSelect.value || "None";
            const convenience = bookingType === "Instant" ? 45 : 25;
            let discount = 0;

            if (recurrence === "Weekly") {
                discount = selectedService.price * 0.05;
            }

            if (recurrence === "Monthly") {
                discount = selectedService.price * 0.10;
            }

            const total = selectedService.price + convenience - discount;
            document.getElementById("summaryService").textContent = selectedService.name;
            document.getElementById("servicePrice").textContent = selectedService.price.toFixed(2);
            document.getElementById("convenienceFee").textContent = convenience.toFixed(2);
            document.getElementById("discountAmount").textContent = discount.toFixed(2);
            document.getElementById("totalPrice").textContent = total.toFixed(2);
        }

        function updateSummary() {
            const serviceText = serviceSelect.options[serviceSelect.selectedIndex]?.text?.split(" - EGP ")[0] || "Choose a service";
            const workerText = workerSelect.options[workerSelect.selectedIndex]?.text || "Choose a worker";
            document.getElementById("summaryService").textContent = serviceText;
            document.getElementById("summaryWorker").textContent = workerText;
            document.getElementById("summarySlot").textContent = dateSelect.value && timeSelect.value ? `${dateSelect.value} ${timeSelect.value}` : "Select step 2";
            document.getElementById("summaryAddress").textContent = addressLineInput.value || "Add in step 3";
            updatePricing();
        }

        nextButtons.forEach(button => {
            button.addEventListener("click", () => updateSteps(Math.min(currentStep + 1, steps.length)));
        });

        prevButtons.forEach(button => {
            button.addEventListener("click", () => updateSteps(Math.max(currentStep - 1, 1)));
        });

        workerSelect.addEventListener("change", syncAvailability);
        serviceSelect.addEventListener("change", updateSummary);
        dateSelect.addEventListener("change", syncTimes);
        timeSelect.addEventListener("change", updateSummary);
        recurrenceSelect.addEventListener("change", updatePricing);
        bookingTypeInputs.forEach(input => input.addEventListener("change", () => {
            syncAvailability();
            updatePricing();
        }));
        addressPreset.addEventListener("change", () => {
            if (addressPreset.value) {
                addressLineInput.value = addressPreset.value;
                updateSummary();
            }
        });
        addressLineInput.addEventListener("input", updateSummary);

        syncAvailability();
        updateSteps(1);
        updateSummary();
    })();
</script>
