@model Shatbly.ViewModels.EarningsDashboardVM

@{
    ViewData["Title"] = "Earnings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Earnings</h2>
        <p class="text-muted mb-0">Track your completed booking income</p>
    </div>

    <a asp-area="Worker" asp-controller="Withdrawal" asp-action="Create" class="btn btn-primary">
        Request Withdrawal
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="page-card p-4">
            <div class="text-muted mb-2">Total Earnings</div>
            <h3 class="mb-0">@Model.TotalEarnings.ToString("C")</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="page-card p-4">
            <div class="text-muted mb-2">Monthly Earnings</div>
            <h3 class="mb-0">@Model.MonthlyEarnings.ToString("C")</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="page-card p-4">
            <div class="text-muted mb-2">Available Balance</div>
            <h3 class="mb-0">@Model.PendingBalance.ToString("C")</h3>
        </div>
    </div>
</div>

<div class="page-card p-4">
    <h5 class="mb-3">Recent Transactions</h5>

    @if (!Model.RecentTransactions.Any())
    {
        <p class="text-muted mb-0">No completed bookings yet.</p>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RecentTransactions)
                {
                    <tr>
                        <td>@item.Date.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge bg-success">@item.Status</span></td>
                        <td class="text-end">@item.Amount.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
