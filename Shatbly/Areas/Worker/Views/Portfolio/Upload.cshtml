@model Shatbly.ViewModels.UploadPortfolioVM

@{
    ViewData["Title"] = "Upload Portfolio Media";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Upload Media</h2>
        <p class="text-muted mb-0">Supported files: JPG, PNG, MP4</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back
    </a>
</div>

<div class="page-card p-4">
    <form asp-action="Upload" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="FileType" class="form-label"></label>
            <select asp-for="FileType" class="form-select">
                <option value="Image">Image</option>
                <option value="Video">Video</option>
            </select>
            <span asp-validation-for="FileType" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="File" class="form-label"></label>
            <input asp-for="File" type="file" class="form-control" accept=".jpg,.jpeg,.png,.mp4" />
            <span asp-validation-for="File" class="text-danger"></span>
            <div class="form-text">
                Images: JPG or PNG up to 5 MB. Videos: MP4 up to 50 MB.
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Upload</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
