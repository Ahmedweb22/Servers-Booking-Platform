@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string IsActive(string controller, string? action = null)
    {
        var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatches = action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return controllerMatches && actionMatches ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Shatbly Worker</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --worker-bg: #f5f7fb;
            --worker-sidebar: #101828;
            --worker-sidebar-muted: #98a2b3;
            --worker-primary: #2563eb;
            --worker-border: #e5e7eb;
        }

        body {
            background: var(--worker-bg);
            min-height: 100vh;
        }

        .worker-shell {
            min-height: 100vh;
            display: flex;
        }

        .worker-sidebar {
            width: 270px;
            background: var(--worker-sidebar);
            color: #fff;
            position: fixed;
            inset: 0 auto 0 0;
            padding: 24px 18px;
        }

        .worker-brand {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: .2px;
            margin-bottom: 28px;
        }

            .worker-brand span {
                color: var(--worker-primary);
            }

        .worker-nav {
            display: grid;
            gap: 8px;
        }

            .worker-nav a {
                color: var(--worker-sidebar-muted);
                text-decoration: none;
                padding: 12px 14px;
                border-radius: 8px;
                font-weight: 500;
                display: block;
            }

                .worker-nav a:hover,
                .worker-nav a.active {
                    background: rgba(255,255,255,.08);
                    color: #fff;
                }

        .worker-main {
            margin-left: 270px;
            width: calc(100% - 270px);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .worker-topbar {
            height: 72px;
            background: #fff;
            border-bottom: 1px solid var(--worker-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .worker-content {
            padding: 32px;
            max-width: 1180px;
            width: 100%;
            margin: 0 auto;
        }

        .page-card {
            background: #fff;
            border: 1px solid var(--worker-border);
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(16, 24, 40, .04);
        }

        .worker-footer {
            margin-top: auto;
            padding: 18px 32px;
            color: #667085;
            border-top: 1px solid var(--worker-border);
            background: #fff;
        }

        @@media (max-width: 991px) {
            .worker-shell {
                display: block;
            }

            .worker-sidebar {
                position: static;
                width: 100%;
                padding: 18px;
            }

            .worker-nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .worker-main {
                margin-left: 0;
                width: 100%;
            }

            .worker-topbar {
                padding: 0 18px;
            }

            .worker-content {
                padding: 18px;
            }
        }
    </style>
</head>
<body>
    <div class="worker-shell">
        <aside class="worker-sidebar">
            <div class="worker-brand">Shatbly<span>.</span></div>

            <nav class="worker-nav">
                <a asp-area="Worker"
                   asp-controller="WorkerProfile"
                   asp-action="Details"
                   class="@IsActive("WorkerProfile")">
                    Profile
                </a>

                <a asp-area="Worker"
                   asp-controller="Availability"
                   asp-action="Index"
                   class="@IsActive("Availability")">
                    Availability
                </a>

                <a asp-area="Worker"
                   asp-controller="Portfolio"
                   asp-action="Index"
                   class="@IsActive("Portfolio")">
                    Portfolio
                </a>

                <a asp-area="Worker"
                   asp-controller="Withdrawal"
                   asp-action="Index"
                   class="@IsActive("Withdrawal")">
                    Withdrawals
                </a>
            </nav>
        </aside>

        <main class="worker-main">
            <header class="worker-topbar">
                <div>
                    <div class="fw-semibold">Worker Dashboard</div>
                    <div class="text-muted small">@DateTime.Now.ToString("dddd, dd MMM yyyy")</div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">@User.Identity?.Name</span>

                    <a asp-area="Identity"
                       asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-sm btn-outline-secondary">
                        Logout
                    </a>
                </div>
            </header>

            <section class="worker-content">
                @if (TempData["Success"] is not null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] is not null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                @RenderBody()
            </section>

            <footer class="worker-footer">
                &copy; @DateTime.Now.Year - Shatbly Worker Panel
            </footer>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>