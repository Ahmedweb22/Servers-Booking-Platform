@model Shatbly.ViewModels.WorkerProfileVM

@{
    ViewData["Title"] = "Worker Profile";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">@Model.WorkerName</h2>
            <p class="text-muted mb-0">Worker profile details</p>
        </div>

        @* <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            Edit Profile
        </a> *@

        <a asp-action="Edit">Edit</a>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="mb-4">
                <h5>Bio</h5>
                <p class="mb-0">@Model.Bio</p>
            </div>

            <hr />

            <div class="row g-3">
                <div class="col-md-4">
                    <strong>Rating</strong>
                    <div>@Model.RatingAvg.ToString("0.00") / 5 (@Model.RatingCount reviews)</div>
                </div>

                <div class="col-md-4">
                    <strong>Availability</strong>
                    <div>
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Unavailable</span>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <strong>Verified</strong>
                    <div>
                        @if (Model.IsVerified)
                        {
                            <span class="badge bg-primary">Verified</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <strong>Accepts Online</strong>
                    <div>@(Model.AcceptsOnline ? "Yes" : "No")</div>
                </div>

                <div class="col-md-4">
                    <strong>Created At</strong>
                    <div>@Model.CreatedAt.ToString("yyyy-MM-dd")</div>
                </div>

                <div class="col-md-4">
                    <strong>CV</strong>
                    <div>
                        @if (!string.IsNullOrWhiteSpace(Model.CVPath))
                        {
                            <a href="@Url.Content(Model.CVPath)" target="_blank" class="btn btn-sm btn-outline-primary">
                                Download CV
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No CV uploaded</span>
                        }
                    </div>
                </div>
            </div>

            <form asp-action="ToggleAvailability" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary">
                    Toggle Availability
                </button>
            </form>
        </div>
    </div>
</div>
